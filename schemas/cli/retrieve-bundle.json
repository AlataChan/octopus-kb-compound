{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "octopus-kb/cli/retrieve-bundle",
  "description": "Successful retrieve-bundle CLI runs touch .octopus-kb/.retrieve-bundle-marker so Claude Code hooks can tell that retrieval happened before Grep.",
  "type": "object",
  "required": ["query", "bundle", "warnings", "token_estimate", "next"],
  "additionalProperties": false,
  "properties": {
    "query": {"type": "string"},
    "bundle": {
      "type": "object",
      "required": ["schema", "index", "concepts", "entities", "raw_sources"],
      "additionalProperties": false,
      "properties": {
        "schema": {"type": "array", "items": {"type": "string"}},
        "index": {"type": "array", "items": {"type": "string"}},
        "concepts": {
          "type": "array",
          "items": {"$ref": "#/$defs/page"}
        },
        "entities": {
          "type": "array",
          "items": {"$ref": "#/$defs/page"}
        },
        "raw_sources": {
          "type": "array",
          "items": {"$ref": "#/$defs/page"}
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "additionalProperties": false,
        "properties": {
          "code": {"type": "string"},
          "message": {"type": "string"}
        }
      }
    },
    "token_estimate": {
      "type": "integer",
      "minimum": 0,
      "description": "Character-based heuristic computed as (total_chars_of_all_bundled_markdown_bodies + 3) // 4; this is not a real tokenizer."
    },
    "next": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "page": {
      "type": "object",
      "required": ["path", "title", "reason"],
      "additionalProperties": false,
      "properties": {
        "path": {"type": "string"},
        "title": {"type": "string"},
        "reason": {
          "type": "string",
          "enum": [
            "title_match",
            "alias_match",
            "related_entities",
            "backlink",
            "schema_anchor",
            "index_anchor",
            "log_anchor"
          ]
        }
      }
    }
  }
}
